{
  "packageId": "ttg.overlay.after-consent",
  "kind": "overlay",
  "controlSet": [
    {
      "id": "control.purpose-binding",
      "type": "purpose-binding",
      "description": "Restrict delegated action to declared purpose and action class"
    },
    {
      "id": "control.chain-depth-limit",
      "type": "delegation-depth",
      "description": "Prevent hidden over-delegation across agent chains"
    },
    {
      "id": "control.withdrawal-enforcement",
      "type": "revocation-check",
      "description": "Pause or deny on withdrawal, harm trigger, or re-consent requirement"
    }
  ],
  "policyRules": [
    {
      "policyId": "policy.after.consent",
      "rules": [
        "Restrict delegated action to declared purpose and action class",
        "Prevent hidden over-delegation across agent chains",
        "Pause or deny on withdrawal, harm trigger, or re-consent requirement"
      ]
    }
  ],
  "threats": [
    {
      "id": "threat.consent-drift",
      "type": "policy-bypass",
      "description": "Delegated use drifts beyond the consented purpose"
    },
    {
      "id": "threat.stale-withdrawal",
      "type": "stale-state",
      "description": "Revoked or narrowed consent is ignored at execution time"
    }
  ],
  "lifecycle": {
    "states": [
      "issued",
      "active",
      "suspended",
      "revoked",
      "expired"
    ],
    "transitions": [
      {
        "id": "transition.issue",
        "from": "state.issued",
        "to": "state.active",
        "trigger": "admission and publication",
        "actor": "maintainer or policy authority",
        "evidenceRequirement": "manifest plus schema present"
      },
      {
        "id": "transition.suspend",
        "from": "state.active",
        "to": "state.suspended",
        "trigger": "challenge, incident, or evidence gap",
        "actor": "policy authority or assessor",
        "evidenceRequirement": "issue or review record"
      },
      {
        "id": "transition.revoke",
        "from": "state.active",
        "to": "state.revoked",
        "trigger": "authority withdrawn or non-conformance confirmed",
        "actor": "policy authority",
        "evidenceRequirement": "revocation record with rationale"
      },
      {
        "id": "transition.resume",
        "from": "state.suspended",
        "to": "state.active",
        "trigger": "issue resolved",
        "actor": "policy authority or maintainer",
        "evidenceRequirement": "updated evidence or corrected policy"
      },
      {
        "id": "transition.expire",
        "from": "state.active",
        "to": "state.expired",
        "trigger": "time bound or freshness window elapsed",
        "actor": "system",
        "evidenceRequirement": "timestamp comparison or expiry check"
      }
    ]
  },
  "notes": [
    "This package is authored as TSMM-native source, not as an external artifact with a TSMM mapping.",
    "Controls and lifecycle semantics are extracted from the package-local TSMM model."
  ]
}