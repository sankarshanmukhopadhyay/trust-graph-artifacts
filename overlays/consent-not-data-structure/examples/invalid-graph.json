      "type": "produces",
      "from": "decision.consent.execution",
      "to": "effect.pause-action",
      "description": "Trust decision produces a downstream effect."
    },
    {
      "id": "consent-not-data-structure.edge.decision-effect.execution.deny-action",
      "type": "produces",
      "from": "decision.consent.execution",
