{
  "packageId": "ttg.overlay.crisis-of-narrative-control",
  "kind": "overlay",
  "controlSet": [
    {
      "id": "control.reason-code-required",
      "type": "decision-explanation",
      "description": "Require structured reasons for material narrative control"
    },
    {
      "id": "control.appeal-route",
      "type": "contestability",
      "description": "Provide bounded path for challenge and review"
    },
    {
      "id": "control.effect-traceability",
      "type": "effect-trace",
      "description": "Trace what downstream effect a control action caused"
    }
  ],
  "policyRules": [
    {
      "policyId": "policy.crisis.of.narrative.control",
      "rules": [
        "Require structured reasons for material narrative control",
        "Provide bounded path for challenge and review",
        "Trace what downstream effect a control action caused"
      ]
    }
  ],
  "threats": [
    {
      "id": "threat.uncontestable-control",
      "type": "governance-opacity",
      "description": "Narrative control occurs without evidence or challenge path"
    },
    {
      "id": "threat.hidden-effect-shaping",
      "type": "effect-opacity",
      "description": "Ranking or suppression effects cannot be inspected"
    }
  ],
  "lifecycle": {
    "states": [
      "issued",
      "active",
      "suspended",
      "revoked",
      "expired"
    ],
    "transitions": [
      {
        "id": "transition.issue",
        "from": "state.issued",
        "to": "state.active",
        "trigger": "admission and publication",
        "actor": "maintainer or policy authority",
        "evidenceRequirement": "manifest plus schema present"
      },
      {
        "id": "transition.suspend",
        "from": "state.active",
        "to": "state.suspended",
        "trigger": "challenge, incident, or evidence gap",
        "actor": "policy authority or assessor",
        "evidenceRequirement": "issue or review record"
      },
      {
        "id": "transition.revoke",
        "from": "state.active",
        "to": "state.revoked",
        "trigger": "authority withdrawn or non-conformance confirmed",
        "actor": "policy authority",
        "evidenceRequirement": "revocation record with rationale"
      },
      {
        "id": "transition.resume",
        "from": "state.suspended",
        "to": "state.active",
        "trigger": "issue resolved",
        "actor": "policy authority or maintainer",
        "evidenceRequirement": "updated evidence or corrected policy"
      },
      {
        "id": "transition.expire",
        "from": "state.active",
        "to": "state.expired",
        "trigger": "time bound or freshness window elapsed",
        "actor": "system",
        "evidenceRequirement": "timestamp comparison or expiry check"
      }
    ]
  },
  "notes": [
    "This package is authored as TSMM-native source, not as an external artifact with a TSMM mapping.",
    "Controls and lifecycle semantics are extracted from the package-local TSMM model."
  ]
}