{
  "packageId": "ttg.overlay.machine-readable-privacy-terms",
  "kind": "overlay",
  "controlSet": [
    {
      "id": "control.purpose-limitation",
      "type": "purpose-control",
      "description": "Restrict processing to declared purpose and lawful basis"
    },
    {
      "id": "control.retention-expiry",
      "type": "retention-control",
      "description": "Terminate use when retention or freshness limits expire"
    },
    {
      "id": "control.onward-transfer-check",
      "type": "sharing-control",
      "description": "Prevent downstream sharing absent permitted transfer terms"
    }
  ],
  "policyRules": [
    {
      "policyId": "policy.machine.readable.privacy.terms",
      "rules": [
        "Restrict processing to declared purpose and lawful basis",
        "Terminate use when retention or freshness limits expire",
        "Prevent downstream sharing absent permitted transfer terms"
      ]
    }
  ],
  "threats": [
    {
      "id": "threat.privacy-term-ignored",
      "type": "policy-bypass",
      "description": "Machine-readable privacy restrictions are not enforced at execution time"
    },
    {
      "id": "threat.unbounded-onward-transfer",
      "type": "data-exfiltration",
      "description": "Downstream sharing exceeds subject-agreed constraints"
    }
  ],
  "lifecycle": {
    "states": [
      "issued",
      "active",
      "suspended",
      "revoked",
      "expired"
    ],
    "transitions": [
      {
        "id": "transition.issue",
        "from": "state.issued",
        "to": "state.active",
        "trigger": "admission and publication",
        "actor": "maintainer or policy authority",
        "evidenceRequirement": "manifest plus schema present"
      },
      {
        "id": "transition.suspend",
        "from": "state.active",
        "to": "state.suspended",
        "trigger": "challenge, incident, or evidence gap",
        "actor": "policy authority or assessor",
        "evidenceRequirement": "issue or review record"
      },
      {
        "id": "transition.revoke",
        "from": "state.active",
        "to": "state.revoked",
        "trigger": "authority withdrawn or non-conformance confirmed",
        "actor": "policy authority",
        "evidenceRequirement": "revocation record with rationale"
      },
      {
        "id": "transition.resume",
        "from": "state.suspended",
        "to": "state.active",
        "trigger": "issue resolved",
        "actor": "policy authority or maintainer",
        "evidenceRequirement": "updated evidence or corrected policy"
      },
      {
        "id": "transition.expire",
        "from": "state.active",
        "to": "state.expired",
        "trigger": "time bound or freshness window elapsed",
        "actor": "system",
        "evidenceRequirement": "timestamp comparison or expiry check"
      }
    ]
  },
  "notes": [
    "This package is authored as TSMM-native source, not as an legacy secondary representation.",
    "Controls and lifecycle semantics are extracted from the package-local TSMM model."
  ]
}