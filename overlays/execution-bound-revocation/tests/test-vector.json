{
  "packageId": "ttg.overlay.execution-bound-revocation",
  "tests": [
    {
      "caseId": "valid-execution-bound-revocation",
      "packageId": "ttg.overlay.execution-bound-revocation",
      "expected": "pass",
      "description": "Current authority and propagation evidence satisfy the temporal governance policy.",
      "inputs": {
        "authority_state": "current",
        "revocation_state": "observed-and-enforced",
        "cache_age_ms": 3000,
        "max_allowed_cache_age_ms": 5000,
        "downstream_state": "not-contaminated"
      },
      "receipts": [
        "revocation-propagation-receipt",
        "execution-authority-state-receipt"
      ]
    },
    {
      "caseId": "invalid-execution-bound-revocation",
      "packageId": "ttg.overlay.execution-bound-revocation",
      "expected": "fail",
      "description": "Execution attempts to rely on stale, partially propagated, or contaminated authority.",
      "inputs": {
        "authority_state": "stale-or-diverged",
        "revocation_state": "not-enforced-at-node",
        "cache_age_ms": 120000,
        "max_allowed_cache_age_ms": 5000,
        "downstream_state": "contaminated"
      },
      "failure": [
        "stale-authority",
        "revocation-lag",
        "missing-propagation-evidence"
      ]
    }
  ]
}
