{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "receipt_id",
    "receipt_type",
    "timestamp",
    "source_essays",
    "policy_id",
    "rule_result",
    "enforcement_action"
  ],
  "properties": {
    "receipt_id": {
      "type": "string"
    },
    "receipt_type": {
      "const": "enforcement-receipt"
    },
    "timestamp": {
      "type": "string"
    },
    "source_essays": {
      "type": "array"
    },
    "signature": {
      "type": "string"
    },
    "policy_id": {
      "type": "string"
    },
    "rule_result": {
      "type": "string"
    },
    "enforcement_action": {
      "type": "string"
    },
    "evidence_reference": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
