{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sankarshanmukhopadhyay/trust-graph-artifacts/main/schemas/authority/artifact.schema.json",
  "title": "TGA authority artifact schema",
  "type": "object",
  "required": ["id", "kind", "title", "status", "tsmmAlignment", "sourceEssays", "purpose", "requiredReceipts", "tests", "authorityScope"],
  "properties": {
    "id": {"type": "string"},
    "kind": {"type": "string", "pattern": "authority"},
    "title": {"type": "string"},
    "status": {"type": "string"},
    "tsmmAlignment": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "sourceEssays": {"type": "array", "minItems": 1},
    "purpose": {"type": "string"},
    "requiredReceipts": {"type": "array", "items": {"type": "string"}},
    "tests": {"type": "array", "items": {"type": "string"}},
    "authorityScope": {"type":"array","items":{"type":"string"}}
  },
  "additionalProperties": true
}
