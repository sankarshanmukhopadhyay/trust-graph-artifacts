{
  "packageId": "ttg.pattern.systemic-controllers",
  "kind": "pattern",
  "controlSet": [
    {
      "id": "control.controller-disclosure",
      "type": "transparency-control",
      "description": "Require declaration of hidden control surfaces and dependencies"
    },
    {
      "id": "control.override-accountability",
      "type": "override-recording",
      "description": "Record who can override or constrain downstream action"
    },
    {
      "id": "control.dependency-mapping",
      "type": "dependency-mapping",
      "description": "Map systemic dependencies that can create concentrated risk"
    }
  ],
  "policyRules": [
    {
      "policyId": "policy.systemic.controllers",
      "rules": [
        "Require declaration of hidden control surfaces and dependencies",
        "Record who can override or constrain downstream action",
        "Map systemic dependencies that can create concentrated risk"
      ]
    }
  ],
  "threats": [
    {
      "id": "threat.hidden-control-lever",
      "type": "opacity-risk",
      "description": "Critical control is exercised without visibility or contestability"
    },
    {
      "id": "threat.unbounded-override",
      "type": "governance-concentration",
      "description": "Operator override changes effects without accountable review"
    }
  ],
  "lifecycle": {
    "states": [
      "issued",
      "active",
      "suspended",
      "revoked",
      "expired"
    ],
    "transitions": [
      {
        "id": "transition.issue",
        "from": "state.issued",
        "to": "state.active",
        "trigger": "admission and publication",
        "actor": "maintainer or policy authority",
        "evidenceRequirement": "manifest plus schema present"
      },
      {
        "id": "transition.suspend",
        "from": "state.active",
        "to": "state.suspended",
        "trigger": "challenge, incident, or evidence gap",
        "actor": "policy authority or assessor",
        "evidenceRequirement": "issue or review record"
      },
      {
        "id": "transition.revoke",
        "from": "state.active",
        "to": "state.revoked",
        "trigger": "authority withdrawn or non-conformance confirmed",
        "actor": "policy authority",
        "evidenceRequirement": "revocation record with rationale"
      },
      {
        "id": "transition.resume",
        "from": "state.suspended",
        "to": "state.active",
        "trigger": "issue resolved",
        "actor": "policy authority or maintainer",
        "evidenceRequirement": "updated evidence or corrected policy"
      },
      {
        "id": "transition.expire",
        "from": "state.active",
        "to": "state.expired",
        "trigger": "time bound or freshness window elapsed",
        "actor": "system",
        "evidenceRequirement": "timestamp comparison or expiry check"
      }
    ]
  },
  "notes": [
    "This package is authored as TSMM-native source, not as an external artifact with a TSMM mapping.",
    "Controls and lifecycle semantics are extracted from the package-local TSMM model."
  ]
}