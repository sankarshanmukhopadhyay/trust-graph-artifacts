{
  "packageId": "ttg.profile.trust-registry-governance-model",
  "kind": "profile",
  "controlSet": [
    {
      "id": "control.operator-scope",
      "type": "operator-scope-check",
      "description": "Bind operator actions to charter and publication mandate"
    },
    {
      "id": "control.registry-status-freshness",
      "type": "publication-freshness",
      "description": "Ensure status changes propagate before relying effects occur"
    },
    {
      "id": "control.revocation-cascade",
      "type": "delegation-revocation",
      "description": "Cascade charter or listing revocation to downstream reliance"
    }
  ],
  "policyRules": [
    {
      "policyId": "policy.trust.registry.governance.model",
      "rules": [
        "Bind operator actions to charter and publication mandate",
        "Ensure status changes propagate before relying effects occur",
        "Cascade charter or listing revocation to downstream reliance"
      ]
    }
  ],
  "threats": [
    {
      "id": "threat.registry-capture",
      "type": "governance-capture",
      "description": "Registry operator uses publication leverage without bounded oversight"
    },
    {
      "id": "threat.delayed-status-update",
      "type": "propagation-delay",
      "description": "Revocation or downgrade does not reach relying parties in time"
    }
  ],
  "lifecycle": {
    "states": [
      "issued",
      "active",
      "suspended",
      "revoked",
      "expired"
    ],
    "transitions": [
      {
        "id": "transition.issue",
        "from": "state.issued",
        "to": "state.active",
        "trigger": "admission and publication",
        "actor": "maintainer or policy authority",
        "evidenceRequirement": "manifest plus schema present"
      },
      {
        "id": "transition.suspend",
        "from": "state.active",
        "to": "state.suspended",
        "trigger": "challenge, incident, or evidence gap",
        "actor": "policy authority or assessor",
        "evidenceRequirement": "issue or review record"
      },
      {
        "id": "transition.revoke",
        "from": "state.active",
        "to": "state.revoked",
        "trigger": "authority withdrawn or non-conformance confirmed",
        "actor": "policy authority",
        "evidenceRequirement": "revocation record with rationale"
      },
      {
        "id": "transition.resume",
        "from": "state.suspended",
        "to": "state.active",
        "trigger": "issue resolved",
        "actor": "policy authority or maintainer",
        "evidenceRequirement": "updated evidence or corrected policy"
      },
      {
        "id": "transition.expire",
        "from": "state.active",
        "to": "state.expired",
        "trigger": "time bound or freshness window elapsed",
        "actor": "system",
        "evidenceRequirement": "timestamp comparison or expiry check"
      }
    ]
  },
  "notes": [
    "This package is authored as TSMM-native source, not as an external artifact with a TSMM mapping.",
    "Controls and lifecycle semantics are extracted from the package-local TSMM model."
  ]
}