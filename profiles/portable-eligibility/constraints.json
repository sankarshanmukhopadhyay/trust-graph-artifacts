{
  "packageId": "ttg.profile.portable-eligibility",
  "kind": "profile",
  "controlSet": [
    {
      "id": "control.portability-bounds",
      "type": "reuse-boundary",
      "description": "Define where and how eligibility can be reused"
    },
    {
      "id": "control.eligibility-freshness",
      "type": "freshness-check",
      "description": "Require live or bounded-fresh status before access"
    },
    {
      "id": "control.dependency-disclosure",
      "type": "dependency-disclosure",
      "description": "Declare external dependencies and governance assumptions for portability"
    }
  ],
  "policyRules": [
    {
      "policyId": "policy.portable.eligibility",
      "rules": [
        "Define where and how eligibility can be reused",
        "Require live or bounded-fresh status before access",
        "Declare external dependencies and governance assumptions for portability"
      ]
    }
  ],
  "threats": [
    {
      "id": "threat.over-portability",
      "type": "context-leakage",
      "description": "Eligibility is reused outside intended context"
    },
    {
      "id": "threat.stale-eligibility",
      "type": "stale-state",
      "description": "Expired or changed eligibility continues granting access"
    }
  ],
  "lifecycle": {
    "states": [
      "issued",
      "active",
      "suspended",
      "revoked",
      "expired"
    ],
    "transitions": [
      {
        "id": "transition.issue",
        "from": "state.issued",
        "to": "state.active",
        "trigger": "admission and publication",
        "actor": "maintainer or policy authority",
        "evidenceRequirement": "manifest plus schema present"
      },
      {
        "id": "transition.suspend",
        "from": "state.active",
        "to": "state.suspended",
        "trigger": "challenge, incident, or evidence gap",
        "actor": "policy authority or assessor",
        "evidenceRequirement": "issue or review record"
      },
      {
        "id": "transition.revoke",
        "from": "state.active",
        "to": "state.revoked",
        "trigger": "authority withdrawn or non-conformance confirmed",
        "actor": "policy authority",
        "evidenceRequirement": "revocation record with rationale"
      },
      {
        "id": "transition.resume",
        "from": "state.suspended",
        "to": "state.active",
        "trigger": "issue resolved",
        "actor": "policy authority or maintainer",
        "evidenceRequirement": "updated evidence or corrected policy"
      },
      {
        "id": "transition.expire",
        "from": "state.active",
        "to": "state.expired",
        "trigger": "time bound or freshness window elapsed",
        "actor": "system",
        "evidenceRequirement": "timestamp comparison or expiry check"
      }
    ]
  },
  "notes": [
    "This package is authored as TSMM-native source, not as an legacy secondary representation.",
    "Controls and lifecycle semantics are extracted from the package-local TSMM model."
  ]
}