{
  "packageId": "ttg.profile.digital-credential-verification-policy-playbook",
  "kind": "profile",
  "controlSet": [
    {
      "id": "control.policy-based-verification",
      "type": "policy-evaluation",
      "description": "Require credential verification to run through policy profile, not cryptography alone"
    },
    {
      "id": "control.exception-routing",
      "type": "exception-handling",
      "description": "Route ambiguous or degraded results to defined review path"
    },
    {
      "id": "control.status-freshness",
      "type": "freshness-check",
      "description": "Require status and supporting evidence freshness at decision time"
    }
  ],
  "policyRules": [
    {
      "policyId": "policy.digital.credential.verification.policy.playbook",
      "rules": [
        "Require credential verification to run through policy profile, not cryptography alone",
        "Route ambiguous or degraded results to defined review path",
        "Require status and supporting evidence freshness at decision time"
      ]
    }
  ],
  "threats": [
    {
      "id": "threat.crypto-only-acceptance",
      "type": "policy-omission",
      "description": "Verifier accepts a technically valid credential absent policy grounds"
    },
    {
      "id": "threat.status-staleness",
      "type": "stale-evidence",
      "description": "Verifier relies on outdated revocation or assurance data"
    }
  ],
  "lifecycle": {
    "states": [
      "issued",
      "active",
      "suspended",
      "revoked",
      "expired"
    ],
    "transitions": [
      {
        "id": "transition.issue",
        "from": "state.issued",
        "to": "state.active",
        "trigger": "admission and publication",
        "actor": "maintainer or policy authority",
        "evidenceRequirement": "manifest plus schema present"
      },
      {
        "id": "transition.suspend",
        "from": "state.active",
        "to": "state.suspended",
        "trigger": "challenge, incident, or evidence gap",
        "actor": "policy authority or assessor",
        "evidenceRequirement": "issue or review record"
      },
      {
        "id": "transition.revoke",
        "from": "state.active",
        "to": "state.revoked",
        "trigger": "authority withdrawn or non-conformance confirmed",
        "actor": "policy authority",
        "evidenceRequirement": "revocation record with rationale"
      },
      {
        "id": "transition.resume",
        "from": "state.suspended",
        "to": "state.active",
        "trigger": "issue resolved",
        "actor": "policy authority or maintainer",
        "evidenceRequirement": "updated evidence or corrected policy"
      },
      {
        "id": "transition.expire",
        "from": "state.active",
        "to": "state.expired",
        "trigger": "time bound or freshness window elapsed",
        "actor": "system",
        "evidenceRequirement": "timestamp comparison or expiry check"
      }
    ]
  },
  "notes": [
    "This package is authored as TSMM-native source, not as an external artifact with a TSMM mapping.",
    "Controls and lifecycle semantics are extracted from the package-local TSMM model."
  ]
}